# Salesforce Off-Ramp environment template.
#
# To use:
#   cp .env.example .env
#   # then fill in the secrets (ANTHROPIC_API_KEY, SF_CLIENT_ID, etc.)
#
# In prod these are sourced from Azure Key Vault / AWS Secrets Manager via
# init-container, never from .env. The .env file is gitignored.

# === Salesforce (per-org) ===
SF_ORG_ALIAS=dev_scratch
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=                                  # Connected App consumer key
SF_USERNAME=integration@example.com
SF_JWT_KEY_PATH=/secrets/sf_jwt.pem            # PEM-encoded RSA private key
SF_API_VERSION=66.0                            # pinned (Spring '26)

# === Pub/Sub API (CDC + Platform Events) ===
SF_PUBSUB_HOST=api.pubsub.salesforce.com:7443
SF_CDC_REPLAY_RECONCILE_THRESHOLD_HOURS=60     # AD-21: trigger re-sync past this lag

# === Infra ===
POSTGRES_DSN=postgresql://offramp:offramp@localhost:5432/offramp
POSTGRES_SHADOW_DSN=postgresql://offramp:offramp@localhost:5432/offramp_shadow
FALKORDB_URL=redis://localhost:6379
EVENT_BUS_BACKEND=redis_streams                # redis_streams | azure_event_hubs | nats
REDIS_STREAMS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=offramp-dev

# === LLM (annotation + Tier 3 agents) ===
# Default: Anthropic Claude Sonnet 4.6 via the Anthropic API.
# To use a self-hosted Llama or OpenAI-compatible endpoint, override BASE_URL
# and MODEL; the annotation harness routes by provider via LLM_BASE_URL host.
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=                                   # paste your sk-ant-... here
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=                             # mirrors LLM_API_KEY for the SDK
LLM_MAX_TOKENS=1024                            # per annotation call
LLM_REQUESTS_PER_MINUTE=50                     # client-side rate guard

# === Provenance ===
ENGRAM_API_URL=http://localhost:8088           # stub backend in Phase 0
F44_NETWORK=base-sepolia                       # base-sepolia | base-mainnet

# === Observability ===
DATADOG_API_KEY=
LOG_LEVEL=INFO
LOG_FORMAT=json                                # json | console
